---
const { id, viewBox = "0 0 400 400", width = "100%", height = "400", ...rest } = Astro.props;
---

<svg id={id} viewBox={viewBox} width={width} height={height} {...rest}></svg>

<script>
    import { geometryDrawings } from '../scripts/pages/geometryPage'; // Dictionary of drawing functions for the geometry page (geometry.mdx)
    import { vectorsDrawings } from '../scripts/pages/vectorsPage'; // Dictionary of drawing functions for the vectors page (vectors.mdx)
    import { ensureSharedMarkerDefs } from '../scripts/core/SVGDrawing'; // Ensures the existence of shared markers (arrows) in the DOM

    // Declare MathJax to avoid TypeScript errors (loaded globally)
    declare const MathJax: any;

    const allDrawings = { ...geometryDrawings, ...vectorsDrawings };

    const initDrawings = async () => {
        // Ensure markers (arrows) are defined
        ensureSharedMarkerDefs();

        // If MathJax is loaded, wait for it to be ready for rendering
        if (typeof MathJax !== 'undefined' && MathJax.startup) {
            try {
                await MathJax.startup.promise;
            } catch (e) {
                console.error("Error esperando a MathJax:", e);
            }
        }

        for (const [id, drawFunc] of Object.entries(allDrawings)) {
            const svg = document.getElementById(id) as Element | null;
            // Check if it exists, is a function, and has NOT been drawn yet (to avoid duplicates)
            if (svg instanceof SVGElement && typeof drawFunc === 'function' && !svg.hasAttribute('data-drawn')) {
                try {
                    drawFunc(svg);
                    svg.setAttribute('data-drawn', 'true'); // Mark as drawn
                } catch (e) {
                    console.error(`❌ Error drawing ${id}:`, e);
                }
            }
        }
    };

    // Execute immediately (module scripts execute after HTML parsing)
    initDrawings();
    
    // Optional support for Astro View Transitions
    document.addEventListener('astro:after-swap', initDrawings);
</script>
